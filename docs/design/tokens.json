{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "meta": {
    "project": "DuaCrypto",
    "version": "2025-05-21",
    "description": "Design tokens for Figma Variables and future CSS implementation. Light/dark modes.",
    "referenceMockup": "docs/mockups/homepage-events-bitcoin.png"
  },
  "color": {
    "primary": {
      "$type": "color",
      "$value": "#F7931A",
      "$description": "Bitcoin orange — CTAs, accents, icons"
    },
    "primary-hover": {
      "$type": "color",
      "$value": { "light": "#E8850F", "dark": "#FFB347" }
    },
    "primary-muted": {
      "$type": "color",
      "$value": "rgba(247, 147, 26, 0.1)"
    },
    "bg-page": {
      "$type": "color",
      "$value": { "light": "#FFFFFF", "dark": "#0B0B0F" }
    },
    "bg-surface": {
      "$type": "color",
      "$value": { "light": "#F8F9FA", "dark": "#14141A" }
    },
    "bg-card": {
      "$type": "color",
      "$value": { "light": "#FFFFFF", "dark": "#1E1E26" }
    },
    "bg-footer": {
      "$type": "color",
      "$value": "#0B0B0F"
    },
    "text-primary": {
      "$type": "color",
      "$value": { "light": "#111111", "dark": "#F3F4F6" }
    },
    "text-secondary": {
      "$type": "color",
      "$value": { "light": "#6B7280", "dark": "#9CA3AF" }
    },
    "text-on-primary": {
      "$type": "color",
      "$value": "#FFFFFF"
    },
    "text-on-footer": {
      "$type": "color",
      "$value": "#E5E7EB"
    },
    "border": {
      "$type": "color",
      "$value": { "light": "#E5E7EB", "dark": "#2D2D35" }
    },
    "partner-tangem": { "$type": "color", "$value": "#00B4D8" },
    "partner-bitget": { "$type": "color", "$value": "#00F0FF" },
    "partner-binance": { "$type": "color", "$value": "#F3BA2F" }
  },
  "font": {
    "family-sans": {
      "$type": "fontFamily",
      "$value": "\"Open Sans\", ui-sans-serif, system-ui, sans-serif"
    },
    "family-display": {
      "$type": "fontFamily",
      "$value": "\"Roboto\", ui-sans-serif, system-ui, sans-serif"
    },
    "weight-regular": { "$type": "fontWeight", "$value": 400 },
    "weight-medium": { "$type": "fontWeight", "$value": 500 },
    "weight-bold": { "$type": "fontWeight", "$value": 700 }
  },
  "fontSize": {
    "display-h1": { "$type": "dimension", "$value": { "mobile": "36px", "desktop": "48px" } },
    "heading-h2": { "$type": "dimension", "$value": "32px" },
    "heading-h3": { "$type": "dimension", "$value": "24px" },
    "heading-h4": { "$type": "dimension", "$value": "20px" },
    "body-l": { "$type": "dimension", "$value": "18px" },
    "body-m": { "$type": "dimension", "$value": "16px" },
    "body-s": { "$type": "dimension", "$value": "14px" },
    "caption": { "$type": "dimension", "$value": "12px" },
    "stat-value": { "$type": "dimension", "$value": "36px" }
  },
  "lineHeight": {
    "tight": { "$type": "number", "$value": 1.2 },
    "normal": { "$type": "number", "$value": 1.4 },
    "relaxed": { "$type": "number", "$value": 1.6 }
  },
  "spacing": {
    "1": { "$type": "dimension", "$value": "4px" },
    "2": { "$type": "dimension", "$value": "8px" },
    "3": { "$type": "dimension", "$value": "12px" },
    "4": { "$type": "dimension", "$value": "16px" },
    "5": { "$type": "dimension", "$value": "20px" },
    "6": { "$type": "dimension", "$value": "24px" },
    "8": { "$type": "dimension", "$value": "32px" },
    "10": { "$type": "dimension", "$value": "40px" },
    "12": { "$type": "dimension", "$value": "48px" },
    "16": { "$type": "dimension", "$value": "64px" },
    "20": { "$type": "dimension", "$value": "80px" }
  },
  "borderRadius": {
    "sm": { "$type": "dimension", "$value": "6px" },
    "md": { "$type": "dimension", "$value": "8px" },
    "lg": { "$type": "dimension", "$value": "12px" },
    "xl": { "$type": "dimension", "$value": "16px" },
    "full": { "$type": "dimension", "$value": "999px" }
  },
  "shadow": {
    "card": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0px",
        "offsetY": "4px",
        "blur": "12px",
        "color": "rgba(0, 0, 0, 0.08)"
      }
    },
    "card-hover": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0px",
        "offsetY": "8px",
        "blur": "24px",
        "color": "rgba(0, 0, 0, 0.12)"
      }
    },
    "nav": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0px",
        "offsetY": "2px",
        "blur": "8px",
        "color": "rgba(0, 0, 0, 0.06)"
      }
    },
    "event-card": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0px",
        "offsetY": "12px",
        "blur": "32px",
        "color": "rgba(0, 0, 0, 0.15)"
      }
    }
  },
  "size": {
    "section-max": { "$type": "dimension", "$value": "1280px" },
    "content-narrow": { "$type": "dimension", "$value": "896px" },
    "nav-height": { "$type": "dimension", "$value": "72px" },
    "touch-min": { "$type": "dimension", "$value": "44px" },
    "logo-nav": { "$type": "dimension", "$value": "42px" },
    "logo-footer": { "$type": "dimension", "$value": "45px" }
  },
  "breakpoint": {
    "mobile": { "$type": "dimension", "$value": "375px" },
    "tablet": { "$type": "dimension", "$value": "768px" },
    "desktop": { "$type": "dimension", "$value": "1440px" },
    "nav-collapse": { "$type": "dimension", "$value": "1024px" }
  },
  "cssMapping": {
    "note": "Planned Tailwind @theme keys after Figma approval",
    "primary": "--color-primary",
    "primary-hover": "--color-primary-dark",
    "bg-page": "--color-page",
    "bg-surface": "--color-surface",
    "bg-card": "--color-card",
    "text-primary": "--color-dark",
    "text-secondary": "--color-secondary",
    "border": "--color-border"
  }
}
