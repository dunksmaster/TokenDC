node_modules/
dist/
.vite/
.wrangler/
.wrangler-test/
_worker.bundle
*.bundle
secrets/
.env
.env.local

# Token/secret temp files (never commit)
*.tmp
cf-pages-token.tmp

# Editor / accidental exports
.cursor/
debug-*.log

# Cursor drag-drop images with path-like names (break Windows git)
**/c__Users*
img/test-c__*

# Mirrored from public/css/dark-mode.css by scripts/generate-agent-assets.mjs
css/dark-mode.css

# Mirrored from css/ by scripts/generate-agent-assets.mjs (for Vite public/)
public/css/brand-logos.css

# Lighthouse / PageSpeed artifacts (npm run pagespeed:baseline)
docs/psi-artifacts/
docs/psi-*.json
scripts/.image-optimize-manifest.json

# Responsive gallery variants (scripts/optimize-images.mjs, build-time)
img/*-*w.webp

# Self-hosted vendor assets (scripts/sync-vendor-assets.mjs)
public/fonts/
public/vendor/
public/css/site-fonts.css
css/site-fonts.css
