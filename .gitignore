# Token/secret temp files (never commit)
*.tmp
cf-pages-token.tmp

# Editor / accidental exports
.cursor/
debug-*.log

# Cursor drag-drop images with path-like names (break Windows git)
**/c__Users*
img/test-c__*

# Mirrored from public/css/dark-mode.css by scripts/generate-agent-assets.mjs
css/dark-mode.css

# Mirrored from css/, lib/, js/ by scripts/generate-agent-assets.mjs (for Vite public/)
public/css/bootstrap.min.css
public/css/style.css
public/lib/
public/js/main.js

# Image optimize cache (scripts/optimize-images.mjs)
scripts/.image-optimize-manifest.json

# Self-hosted vendor assets (scripts/sync-vendor-assets.mjs)
public/fonts/
public/vendor/
public/css/site-fonts.css
css/site-fonts.css
